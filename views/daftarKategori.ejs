<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Daftar Kategori</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous"></head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css">
<body>
    <%- include('./Layout/navbar') %>
    
    <div class="container mt-5">
        <div class="row my-4">
            <div class="col-lg-12">
                <div class="table-responsive">
                    <table class="table table-bordered align-middle text-center">
                        <thead class="table-success">
                            <tr class="table-success">
                                <th>Nama Kategori</th>
                                <th>Edit</th>
                                <th>Delete</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% kategori.forEach((row, index) => { %>
                                <tr class="align-miiddle">
                                    <td><%= row.nama_kategori%></td>
                                    <td>
                                        <a href="/kategori/edit/<%= row._id %>" class="text-success">
                                            <i class="fa-solid fa-edit fa-lg text-dark"></i>
                                        </a>
                                    </td>
                                    <th>
                                        <a href="/kategori/delete/<%= row._id %>" class="text-success">
                                            <i class="fa-solid fa-trash fa-lg text-dark"></i>
                                        </a>
                                    </th>
                                </tr>
                          <%  }) %>
                        </tbody>
                    </table>
                </div>
                <div class="text-end">
                    <a href="/kategori/tambah" class="btn   btn-success mt-3">= Tambah Kategori</a>
                </div>
            </div>
        </div>
    </div>
</body>
</html>